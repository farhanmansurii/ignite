{
  "name": "@farhanmansuri/ignite-js",
  "version": "2.0.0",
  "description": "Vanilla JS client for serverless cold-start warming — framework-agnostic",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": ["dist", "LICENSE"],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/farhanmansurii/ignite.git",
    "directory": "packages/js"
  },
  "homepage": "https://github.com/farhanmansurii/ignite/tree/master/packages/js#readme",
  "bugs": {
    "url": "https://github.com/farhanmansurii/ignite/issues"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run"
  },
  "keywords": ["serverless", "cold-start", "pre-warming", "performance", "vanilla-js"],
  "dependencies": {
    "@farhanmansuri/ignite-core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
